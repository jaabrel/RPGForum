@page
@model RPGForum.Pages.FeedForumModel
@{
    ViewData["Title"] = "Fórum de Builds";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <div>
            <h1 class="h2 mb-1 fw-bold text-primary"><i class="bi bi-globe me-2"></i>Fórum Global</h1>
            <p class="text-muted mb-0">Descobre, discute e avalia as melhores builds da comunidade.</p>
        </div>
        @if (User.Identity!.IsAuthenticated)
        {
            <a asp-page="/Build/Create" class="btn btn-primary shadow-sm px-4">
                <i class="bi bi-plus-lg me-2"></i>Publicar Build
            </a>
        }
    </div>

    <!-- Filtros de Pesquisa Avançados -->
    <div class="card shadow-sm border-0 mb-5 bg-light rounded-4">
        <div class="card-body p-4">
            <form method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold text-secondary"><i class="bi bi-search me-1"></i>O que procuras?</label>
                        <input type="text" name="Pesquisa" value="@Model.Pesquisa"
                               class="form-control form-control-lg border-0 shadow-sm" placeholder="Título, descrição ou tags..." />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold text-secondary"><i class="bi bi-person-badge me-1"></i>Personagem</label>
                        <select name="PersonagemId" class="form-select form-select-lg border-0 shadow-sm">
                            <option value="">Todas as Personagens</option>
                            @foreach (var p in Model.Personagens)
                            {
                                <option value="@p.Id" selected="@(Model.PersonagemId == p.Id)">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold text-secondary"><i class="bi bi-people me-1"></i>Autor</label>
                        <input type="text" name="UtilizadorNome" value="@Model.UtilizadorNome"
                               class="form-control form-control-lg border-0 shadow-sm" placeholder="Nome do autor..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold text-secondary"><i class="bi bi-sort-down me-1"></i>Ordenar</label>
                        <select name="Ordenar" class="form-select form-select-lg border-0 shadow-sm">
                            <option value="recente" selected="@(Model.Ordenar == "recente")">Mais Recentes</option>
                            <option value="popular" selected="@(Model.Ordenar == "popular")">Mais Populares (Gostos)</option>
                            <option value="nivel" selected="@(Model.Ordenar == "nivel")">Nível mais Alto</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm fw-bold">Filtrar</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Lista de Resultados / Feed -->
    @if (!Model.Builds.Any())
    {
        <div class="text-center py-5">
            <div class="mb-4 text-muted">
                <i class="bi bi-inbox fs-1"></i>
            </div>
            <h3 class="fw-bold text-secondary">Nenhuma build encontrada</h3>
            <p class="text-muted">Não encontrámos resultados para os teus filtros. Tenta pesquisar por outras palavras.</p>
            @if (User.Identity!.IsAuthenticated)
            {
                <a asp-page="/Build/Create" class="btn btn-outline-primary mt-3 px-4 rounded-pill">Sê o primeiro a publicar!</a>
            }
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3 px-1">
            <p class="text-muted small mb-0 fw-semibold">A mostrar @Model.Builds.Count resultado(s)</p>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var build in Model.Builds)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden build-card-hover transition-all">
                        <!-- Cabeçalho do Card: Personagem e Nível -->
                        <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                            <span class="badge bg-dark text-white rounded-pill px-3 py-2 shadow-sm">
                                <i class="bi bi-person-fill me-1"></i> @(build.CharClass?.Name ?? "Desconhecido")
                            </span>
                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2 shadow-sm fw-bold">
                                Lvl @build.Level
                            </span>
                        </div>

                        <!-- Corpo do Card -->
                        <div class="card-body">
                            <h4 class="card-title fw-bold mb-3 line-clamp-2" style="height: 3rem;">
                                <a asp-page="/Build/Details" asp-route-id="@build.Id"
                                   class="text-decoration-none text-dark stretched-link">
                                    @build.Title
                                </a>
                            </h4>

                            <p class="card-text text-muted small line-clamp-3 mb-0" style="height: 4.5rem; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                                @(string.IsNullOrEmpty(build.Description) ? "Sem descrição disponível para esta build." : build.Description)
                            </p>
                        </div>

                        <!-- Rodapé do Card: Autor e Interações -->
                        <div class="card-footer bg-light border-0 py-3 mt-auto">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="small fw-semibold text-dark mb-0 lh-1">@(build.User?.UserName ?? "Desconhecido")</span>
                                        <span class="text-muted" style="font-size: 0.75rem;">@build.CreatedAt.ToString("dd MMM yyyy")</span>
                                    </div>
                                </div>
                                <div class="d-flex gap-3 text-secondary fw-semibold">
                                    <div class="d-flex align-items-center gap-1" title="Gostos">
                                        <i class="bi bi-heart-fill text-danger"></i> <span>@build.Likes.Count</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-1" title="Comentários">
                                        <i class="bi bi-chat-dots-fill text-primary"></i> <span>@build.Comments.Count</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Paginação -->
        @if (Model.TotalPaginas > 1)
        {
            <nav aria-label="Navegação de páginas" class="mt-5 d-flex justify-content-center">
                <ul class="pagination">
                    <li class="page-item @(Model.TemPaginaAnterior ? "" : "disabled")">
                        <a class="page-link" asp-page="/FeedForum" 
                           asp-route-Pagina="@(Model.PaginaAtual - 1)" 
                           asp-route-Pesquisa="@Model.Pesquisa"
                           asp-route-PersonagemId="@Model.PersonagemId"
                           asp-route-UtilizadorNome="@Model.UtilizadorNome"
                           asp-route-Ordenar="@Model.Ordenar" aria-label="Anterior">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPaginas; i++)
                    {
                        <li class="page-item @(i == Model.PaginaAtual ? "active" : "")">
                            <a class="page-link" asp-page="/FeedForum" 
                               asp-route-Pagina="@i"
                               asp-route-Pesquisa="@Model.Pesquisa"
                               asp-route-PersonagemId="@Model.PersonagemId"
                               asp-route-UtilizadorNome="@Model.UtilizadorNome"
                               asp-route-Ordenar="@Model.Ordenar">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.TemProximaPagina ? "" : "disabled")">
                        <a class="page-link" asp-page="/FeedForum" 
                           asp-route-Pagina="@(Model.PaginaAtual + 1)"
                           asp-route-Pesquisa="@Model.Pesquisa"
                           asp-route-PersonagemId="@Model.PersonagemId"
                           asp-route-UtilizadorNome="@Model.UtilizadorNome"
                           asp-route-Ordenar="@Model.Ordenar" aria-label="Seguinte">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

<style>
    .build-card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .build-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>

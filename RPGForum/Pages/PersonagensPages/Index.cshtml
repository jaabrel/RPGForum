@page
@model RPGForum.Pages.PersonagensPages.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Personagens[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Personagens[0].Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Personagens[0].ImageUrl)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Personagens[0].Builds)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Personagens) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Name)
            </td>
            <td>
                @Html.DisplayFor(model => item.Description)
            </td>
            <td>
                @Html.DisplayFor(model => item.ImageUrl)
            </td>
            <td>
                @Html.DisplayFor(model => item.Builds)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

@page
@model RPGForum.Pages.Admin.Armas.EditModel
@{
    ViewData["Title"] = "Editar Arma";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white">
                    <h3 class="mb-0 h5">⚙️ Editar Arma: @Model.Arma.Name</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Arma.Id" />

                        <div class="mb-3">
                            <label asp-for="Arma.Name" class="form-label fw-bold">Nome da Arma</label>
                            <input asp-for="Arma.Name" class="form-control" />
                            <span asp-validation-for="Arma.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Arma.Type" class="form-label fw-bold">Tipo da Arma</label>
                            <input asp-for="Arma.Type" class="form-control" />
                            <span asp-validation-for="Arma.Type" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Arma.Description" class="form-label fw-bold">Descrição</label>
                            <textarea asp-for="Arma.Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Arma.Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Arma.ImageUrl" class="form-label fw-bold">URL da Imagem</label>
                            <input asp-for="Arma.ImageUrl" class="form-control" />
                            <span asp-validation-for="Arma.ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

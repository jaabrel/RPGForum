@page
@model RPGForum.Pages.Admin.Armas.CreateModel
@{
    ViewData["Title"] = "Criar Arma";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0 h5">⚔️ Criar Nova Arma</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Arma.Name" class="form-label fw-bold">Nome da Arma</label>
                            <input asp-for="Arma.Name" class="form-control" placeholder="Ex: Espada de Ferro, Cajado de Fogo..." />
                            <span asp-validation-for="Arma.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Arma.Type" class="form-label fw-bold">Tipo da Arma</label>
                            <input asp-for="Arma.Type" class="form-control" placeholder="Ex: Espada, Cajado, Arco, Adaga..." />
                            <span asp-validation-for="Arma.Type" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Arma.Description" class="form-label fw-bold">Descrição</label>
                            <textarea asp-for="Arma.Description" class="form-control" rows="4" placeholder="Descreva os atributos e características especiais desta arma..."></textarea>
                            <span asp-validation-for="Arma.Description" class="text-danger small"></span>
                        </div>

                        <!-- Bónus de Estatísticas -->
                        <div class="card mb-4 border border-light shadow-sm">
                            <div class="card-header bg-dark text-white fw-semibold">📈 Bónus de Estatísticas</div>
                            <div class="card-body">
                                <p class="text-muted small">Insira os bónus de atributos fornecidos por esta arma (deixe em branco ou 0 para atributos não afetados).</p>
                                <div class="row row-cols-2 row-cols-md-3 g-3">
                                    @{
                                        var availableStats = new[] { "HP", "Força", "Defesa", "Magia", "Resistência", "Velocidade" };
                                    }
                                    @foreach (var stat in availableStats)
                                    {
                                        <div>
                                            <label class="form-label fw-bold small">@stat</label>
                                            <input type="number" name="SelectedStats[@stat]" class="form-control" value="0" />
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Criar Arma</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

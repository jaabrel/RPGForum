@page
@model RPGForum.Pages.Admin.Personagens.CreateModel
@{
    ViewData["Title"] = "Criar Personagem / Classe";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0 h5">🛡️ Criar Nova Personagem / Classe</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Personagem.Name" class="form-label fw-bold">Nome da Classe</label>
                            <input asp-for="Personagem.Name" class="form-control" placeholder="Ex: Guerreiro, Mago, Arqueiro..." />
                            <span asp-validation-for="Personagem.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Personagem.Description" class="form-label fw-bold">Descrição</label>
                            <textarea asp-for="Personagem.Description" class="form-control" rows="4" placeholder="Descreva as características principais desta classe..."></textarea>
                            <span asp-validation-for="Personagem.Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Personagem.ImageUrl" class="form-label fw-bold">URL da Imagem</label>
                            <input asp-for="Personagem.ImageUrl" class="form-control" placeholder="https://exemplo.com/imagem.png" />
                            <span asp-validation-for="Personagem.ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Criar Personagem</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

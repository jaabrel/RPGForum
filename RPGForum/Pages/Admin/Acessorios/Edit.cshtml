@page
@model RPGForum.Pages.Admin.Acessorios.EditModel

@{
    ViewData["Title"] = "Editar Acessório";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white">
                    <h3 class="mb-0 h5">⚙️ Editar Acessório: @Model.Acessorio.Name</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Acessorio.Id" />

                        <div class="mb-3">
                            <label asp-for="Acessorio.Name" class="form-label fw-bold">Nome do Acessório</label>
                            <input asp-for="Acessorio.Name" class="form-control" />
                            <span asp-validation-for="Acessorio.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Acessorio.Type" class="form-label fw-bold">Tipo de Acessório</label>
                            <input asp-for="Acessorio.Type" class="form-control" />
                            <span asp-validation-for="Acessorio.Type" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Acessorio.Description" class="form-label fw-bold">Descrição</label>
                            <textarea asp-for="Acessorio.Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Acessorio.Description" class="text-danger small"></span>
                        </div>

                        <!-- Bónus de Estatísticas -->
                        <div class="card mb-4 border border-light shadow-sm">
                            <div class="card-header bg-dark text-white fw-semibold">📈 Bónus de Estatísticas</div>
                            <div class="card-body">
                                <p class="text-muted small">Insira os bónus de atributos fornecidos por esta arma (deixe em branco ou 0 para atributos não afetados).</p>
                                <div class="row row-cols-2 row-cols-md-3 g-3">
                                    @{
                                        var availableStats = new[] { "HP", "Força", "Defesa", "Magia", "Resistência", "Velocidade" };
                                    }
                                    @foreach (var stat in availableStats)
                                    {
                                        var val = Model.SelectedStats.ContainsKey(stat) ? Model.SelectedStats[stat] : 0;
                                        <div>
                                            <label class="form-label fw-bold small">@stat</label>
                                            <input type="number" name="SelectedStats[@stat]" class="form-control" value="@val" />
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

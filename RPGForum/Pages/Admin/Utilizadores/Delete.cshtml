@page "{id:int}"
@model RPGForum.Pages.Admin.Utilizadores.DeleteModel
@{
    ViewData["Title"] = "Eliminar Utilizador";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="glass-card p-5 border border-danger">
            <div class="mb-4 text-center">
                <h2 class="title fw-black text-danger">⚠️ Eliminar Utilizador</h2>
                <p class="text-muted">Esta ação é irreversível e removerá o utilizador de forma permanente.</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>
                <input type="hidden" asp-for="Utilizador.Id" />

                <div class="alert alert-warning mb-4">
                    <strong>Atenção:</strong> Ao eliminar o utilizador <strong>@Model.Utilizador.UserName</strong> (@Model.Utilizador.Email), todas as publicações, gostos e comentários associados poderão ser afetados ou removidos.
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-4 text-muted">Nome</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Utilizador.UserName</dd>

                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Utilizador.Email</dd>

                    <dt class="col-sm-4 text-muted">Função</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Utilizador.Role</dd>
                </dl>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger flex-grow-1">🔥 Confirmar Eliminação</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@page "{id:int}"
@model RPGForum.Pages.Admin.Utilizadores.DetailsModel
@{
    ViewData["Title"] = "Detalhes do Utilizador";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="glass-card p-5">
            <div class="mb-4 text-center">
                <!-- Circular Avatar Initial -->
                <div class="user-avatar-circle mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2.5rem; line-height: 80px;">
                    @Model.Utilizador.Username.Substring(0, 1).ToUpper()
                </div>
                <h2 class="title fw-black">@Model.Utilizador.Username</h2>
                <p class="text-muted mb-0">Perfil de Utilizador do Fórum</p>
            </div>

            <!-- Details List -->
            <div class="mb-4">
                <h5 class="fw-bold border-bottom pb-2 mb-3">Informações Gerais</h5>
                <dl class="row">
                    <dt class="col-sm-4 text-muted">ID da Base de Dados</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Utilizador.Id</dd>

                    <dt class="col-sm-4 text-muted">Endereço de Email</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Utilizador.Email</dd>

                    <dt class="col-sm-4 text-muted">Função / Role</dt>
                    <dd class="col-sm-8">
                        @if (Model.Utilizador.Role == "Administrator")
                        {
                            <span class="badge bg-danger">Administrador</span>
                        }
                        else if (Model.Utilizador.Role == "Manager")
                        {
                            <span class="badge bg-warning text-dark">Moderador</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Registado</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted">Data de Criação</dt>
                    <dd class="col-sm-8">@Model.Utilizador.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4 text-muted">Nome do Identity</dt>
                    <dd class="col-sm-8 text-monospace small">@Model.Utilizador.IdentityUserName</dd>
                </dl>
            </div>

            <!-- Stats grid -->
            <div class="mb-4">
                <h5 class="fw-bold border-bottom pb-2 mb-3">Atividade no Fórum</h5>
                <div class="row text-center g-3">
                    <div class="col-4">
                        <div class="p-3 border rounded bg-light">
                            <h3 class="fw-black text-primary mb-1">@Model.TotalBuilds</h3>
                            <span class="text-muted small">Builds</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 border rounded bg-light">
                            <h3 class="fw-black text-success mb-1">@Model.TotalComments</h3>
                            <span class="text-muted small">Comentários</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 border rounded bg-light">
                            <h3 class="fw-black text-warning mb-1">@Model.TotalLikes</h3>
                            <span class="text-muted small">Likes</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex gap-2 border-top pt-4">
                <a asp-page="./Edit" asp-route-id="@Model.Utilizador.Id" class="btn btn-primary flex-grow-1">Editar Perfil</a>
                <a asp-page="./Delete" asp-route-id="@Model.Utilizador.Id" class="btn btn-outline-danger">Eliminar</a>
                <a asp-page="./Index" class="btn btn-outline-secondary">Voltar</a>
            </div>
        </div>
    </div>
</div>

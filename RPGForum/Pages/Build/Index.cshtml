@page
@model RPGForum.Pages.Build.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Build[0].UtilizadorID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Build[0].CharacterId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Build[0].Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Build[0].Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Build[0].Level)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Build[0].CreatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Build[0].UpdatedAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Build) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.UtilizadorID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CharacterId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Level)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UpdatedAt)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

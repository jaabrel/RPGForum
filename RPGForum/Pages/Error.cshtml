@page "{code?}"
@model ErrorModel
@{
    ViewData["Title"] = "Erro";
    var message = "Ocorreu um erro ao processar o seu pedido.";
    var subMessage = "Lamentamos o incómodo. Por favor, tente novamente mais tarde.";

    if (Model.StatusCode == 404)
    {
        message = "Página Não Encontrada (404)";
        subMessage = "A página que procura não existe ou foi movida.";
    }
    else if (Model.StatusCode == 403)
    {
        message = "Acesso Negado (403)";
        subMessage = "Não tem permissões para aceder a este recurso.";
    }
}

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-1 text-danger fw-bold">Oops!</h1>
        <h2 class="mb-4">@message</h2>
        <p class="lead text-muted mb-5">@subMessage</p>

        <div class="mb-4">
            <a asp-page="/Index" class="btn btn-primary btn-lg px-4 me-2">Voltar ao Início</a>
            <a asp-page="/FeedForum" class="btn btn-outline-secondary btn-lg px-4">Ir para o Fórum</a>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="mt-5 pt-4 border-top">
                <p class="text-muted small">
                    <strong>ID do Pedido:</strong> <code>@Model.RequestId</code>
                </p>
            </div>
        }
    </div>
</div>

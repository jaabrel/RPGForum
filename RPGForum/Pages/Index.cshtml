@page
@model IndexModel
@{
    ViewData["Title"] = "Bem-vindo ao RPGForum!";
}

<div class="container py-4">
    <!-- Hero Section -->
    <div class="text-center py-5 px-3 mb-5 glass-card position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(99,102,241,0.05) 100%);">
        <div class="position-relative z-index-1">
            <h1 class="display-3 fw-black mb-3 title" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">⚔️ RPGForum</h1>
            <p class="lead fs-4 text-muted max-w-2xl mx-auto mb-4" style="max-width: 600px; margin: 0 auto;">
                A arena definitiva para partilhares as tuas melhores builds, debateres estratégias e encontrares o estilo perfeito para o teu personagem!
            </p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-page="/FeedForum" class="btn btn-lg btn-primary shadow-sm px-4">
                    🎮 Entrar no Fórum
                </a>
                @if (!User.Identity!.IsAuthenticated)
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-lg btn-secondary px-4">
                        ✨ Criar Conta
                    </a>
                }
                else
                {
                    <a asp-page="/Build/Index" class="btn btn-lg btn-secondary px-4">
                        🛡️ As Minhas Builds
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Fun Features Grid -->
    <h2 class="text-center title mb-4 fs-2">Personagens Lendárias</h2>
    <div class="row g-4 mb-5 justify-content-center">
        <div class="col-md-4 col-sm-6">
            <div class="glass-card p-4 text-center h-100">
                <div class="fs-1 mb-2">⚔️</div>
                <h4 class="fw-bold mb-2 text-primary">Ichigo Kurosaki</h4>
                <p class="text-muted small mb-0">Shinigami substituto, portador da icónica Zanpakutou Zangetsu e mestre do Getsuga Tenshou.</p>
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="glass-card p-4 text-center h-100">
                <div class="fs-1 mb-2">💥</div>
                <h4 class="fw-bold mb-2 text-primary">Goku</h4>
                <p class="text-muted small mb-0">Lendário guerreiro Saiyajin, mestre de artes marciais e defensor da Terra com o seu Kamehameha.</p>
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="glass-card p-4 text-center h-100">
                <div class="fs-1 mb-2">🌀</div>
                <h4 class="fw-bold mb-2 text-primary">Sonic the Hedgehog</h4>
                <p class="text-muted small mb-0">O ouriço azul mais rápido do mundo, defensor da liberdade com a sua velocidade supersónica.</p>
            </div>
        </div>
    </div>
</div>

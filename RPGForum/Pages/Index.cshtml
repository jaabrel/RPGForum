@page
@model IndexModel
@{
    ViewData["Title"] = "Página Inicial";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">⚔️ RPGForum</h1>
        <p class="lead">A sua plataforma para partilha e descoberta de builds de RPG.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Informações do Projeto</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th scope="row" style="width: 30%">Curso:</th>
                                <td>Licenciatura em Engenharia Informática</td>
                            </tr>
                            <tr>
                                <th scope="row">Disciplina:</th>
                                <td>Desenvolvimento Web</td>
                            </tr>
                            <tr>
                                <th scope="row">Ano Letivo:</th>
                                <td>2025/2026 - 2º Ano, 2º Semestre</td>
                            </tr>
                            <tr>
                                <th scope="row">Autores:</th>
                                <td>
                                    <ul class="list-unstyled mb-0">
                                        <li>[Inserir Nome] - [Inserir Número]</li>
                                        <li>[Inserir Nome] - [Inserir Número]</li>
                                    </ul>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Tecnologias e Bibliotecas</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge bg-info text-dark">ASP.NET Core 10.0</span>
                        <span class="badge bg-info text-dark">Razor Pages</span>
                        <span class="badge bg-info text-dark">Entity Framework Core</span>
                        <span class="badge bg-info text-dark">SQLite</span>
                        <span class="badge bg-info text-dark">Bootstrap 5</span>
                        <span class="badge bg-info text-dark">jQuery</span>
                        <span class="badge bg-info text-dark">SignalR</span>
                        <span class="badge bg-info text-dark">JWT (API)</span>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Acesso de Demonstração (Administrador)</h5>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Login:</strong> <code>admin@mail.pt</code></p>
                    <p class="mb-0"><strong>Password:</strong> <code>Aa0_aa</code></p>
                </div>
            </div>
        </div>
    </div>
</div>
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using RPGForum.Models
@inject SignInManager<Utilizadores> SignInManager
@inject UserManager<Utilizadores> UserManager
@inject RPGForum.Data.ApplicationDbContext DbContext

@{
    string firstLetter = "U";
    string displayUsername = "";
    if (SignInManager.IsSignedIn(User))
    {
        var identityName = User.Identity?.Name;
        var utilizador = await DbContext.Utilizadores.FirstOrDefaultAsync(u => u.UserName == identityName || u.Email == identityName);
        if (utilizador != null)
        {
            displayUsername = utilizador.UserName;
            if (!string.IsNullOrEmpty(displayUsername))
            {
                firstLetter = displayUsername.Substring(0, 1).ToUpper();
            }
        }
        else
        {
            displayUsername = identityName ?? "Utilizador";
            firstLetter = displayUsername.Substring(0, 1).ToUpper();
        }
    }
}

<ul class="navbar-nav align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item me-3">
        <a class="nav-link d-flex align-items-center gap-2 py-1" asp-area="Identity" asp-page="/Account/Manage/Index" title="Gerir Perfil">
            <span class="user-avatar-circle">@firstLetter</span>
            <span class="fw-semibold text-secondary">@displayUsername</span>
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link py-1" style="font-weight: 600; color: #64748b; text-decoration: none;">Sair</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Registar</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Iniciar Sessão</a>
    </li>
}
</ul>

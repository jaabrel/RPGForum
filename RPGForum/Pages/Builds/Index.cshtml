@page
@model RPGForum.Pages.Builds.IndexModel
@{
    ViewData["Title"] = "As minhas Builds";
}

<div class="container py-5">
    <div class="text-center py-5 mb-5 position-relative">
        <div class="mb-3 d-inline-block px-3 py-1 glass-card" style="font-size: 0.85rem; color: var(--accent-secondary); border-color: rgba(6, 182, 212, 0.3);">
            ✨  Bem Vindo ao RPG Forum ✨
        </div>
        <h1 class="display-3 fw-black title mb-3"> ⚔️ RPGFORUM</h1>
        <p class="lead text-muted mx-auto mb-4" style="max-width: 650px; font-size: 1.15rem; line-height: 1.6;">
            Aqui podes criar, partilhar e analisar <strong class="text-white">Builds de vários personagens</strong>. É aqui que descobrir como otimizares o teu personagem para teres uma Build mais eficaz!
        </p>

        <div class="d-flex justify-content-center gap-3 mt-4">
            <a asp-page"/ForumFeed" class="btn-primary d-flex align-items-center gap-2">
                🔮 Explorar Fórum
            </a>
            @if (User.Identity!.IsAuthenticated)
            {
                <a asp-page="/Builds/Create" class="btn btn-secondary">
                 🛡️Criar Nova Build
                </a>
            }
            else
            {
                <a href="/Identity/Account/Register" class="btn btn-secondary">
                    📜 Registar Utilizador
                </a>
            }
        </div>
    </div>


    <div class="col-lg-5">
        <div class="card glass-card h-100 p-4 position-relative overflow-hidden" style="border-color: rgba(245, 158, 11, 0.15);">
            <div class="position-absolute" style="top: 0; right: 0; width: 80px; height: 80px; background: radial-gradient(circle, rgba(245, 158, 11, 0.15) 0%, transparent 70%);"></div>
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="p-3 rounded-3" style="background: rgba(245, 158, 11, 0.1);">
                    <span style="font-size: 1.8rem;">👑</span>
                </div>
                <div>
                    <h4 class="fw-bold mb-0" style="color: var(--accent-warning);">Acesso de Demonstração</h4>
                    <small class="text-muted">Credendiais de Administrador</small>
                </div>
            </div>
            <p class="text-muted mb-4" style="font-size: 0.95rem;">Utilize os seguintes dados de teste para aceder à área de administração onde poderá gerir classes, armas e acessórios:
            </p>

        </div>
    </div>





</div>

}


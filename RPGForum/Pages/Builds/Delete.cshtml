@page "{id:int}"
@model RPGForum.Pages.Builds.DeleteModel
@{
    ViewData["Title"] = "Apagar Build";
}

<div class="row justify-content-center">
    <div class="col-lg-6">

        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="Index">As Minhas Builds</a></li>
                <li class="breadcrumb-item active">Apagar</li>
            </ol>
        </nav>

        <div class="card border-danger">
            <div class="card-header bg-danger text-white fw-semibold">
                Confirmar Eliminação
            </div>
            <div class="card-body">
                <p class="mb-1">Tens a certeza que queres apagar a seguinte build?</p>
                <p class="text-danger fw-semibold fs-5">@Model.Build.Title</p>

                <ul class="list-unstyled text-muted small mb-4">
                    <li><strong>Classe:</strong> @Model.Build.CharClass?.Name</li>
                    <li><strong>Nível:</strong> @Model.Build.Level</li>
                    <li><strong>Gostos:</strong> @Model.Build.Likes.Count</li>
                    <li><strong>Comentários:</strong> @Model.Build.Comments.Count</li>
                </ul>

                <div class="alert alert-warning small" role="alert">
                    Esta ação é irreversível. Todos os comentários e gostos associados serão eliminados.
                </div>

                <form method="post" asp-route-id="@Model.Build.Id">
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-danger">Apagar definitivamente</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

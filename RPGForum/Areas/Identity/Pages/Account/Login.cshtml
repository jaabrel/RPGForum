@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar Sessão";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="glass-card p-5">
            <div class="text-center mb-4">
                <h2 class="title fw-black">⚔️ Iniciar Sessão</h2>
                <p class="text-muted">Bem-vindo de volta, aventureiro!</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <!-- Email Input -->
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-semibold">Endereço de Email / Utilizador</label>
                    <input asp-for="Input.Email" class="form-control form-control-custom" autocomplete="username" placeholder="heroi@mail.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <!-- Password Input -->
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Input.Password" class="form-label fw-semibold mb-0">Palavra-passe</label>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="friendly-link small text-decoration-none">
                            Recuperar Palavra-passe
                        </a>
                    </div>
                    <div class="password-container">
                        <input asp-for="Input.Password" type="password" id="password-field" class="form-control form-control-custom" autocomplete="current-password" placeholder="Escreve a tua senha..." />
                        <button type="button" class="password-toggle-btn" onclick="togglePasswordVisibility('password-field', this)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0"/></svg>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <!-- Remember Me Checkbox -->
                <div class="form-check mb-4">
                    <input class="form-check-input" asp-for="Input.RememberMe" style="cursor: pointer;" />
                    <label asp-for="Input.RememberMe" class="form-check-label text-muted small" style="cursor: pointer;">
                        Lembrar-me neste dispositivo
                    </label>
                </div>

                <!-- Submit Button -->
                <button id="login-submit" type="submit" class="w-100 btn btn-primary mb-3">
                    🎮 Entrar na Taverna
                </button>

                <!-- Navigation link -->
                <div class="text-center mt-3">
                    <p class="mb-0 text-muted small">
                        Ainda não tens conta? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="friendly-link">Regista-te aqui</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const eyeOpenSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0"/></svg>`;
        const eyeClosedSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a8.8 8.8 0 0 0-2.79.444l.77.77a7.7 7.7 0 0 1 2.02-.214c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8c-.058.087-.135.194-.225.318l1.356 1.356zM11.97 9.85l1.09 1.09c.38-.45.698-.93.94-1.39A13 13 0 0 0 1.173 8c.086-.13.195-.288.302-.437L9.27 14.284a1.8 1.8 0 0 0 .707.001l1.993-4.435zM4.14 5.548A13 13 0 0 0 1.172 8c.195.288.462.62.8 1.002l1.852-1.852a3.4 3.4 0 0 1 1.226-1.226L5.05 6.454z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0"/></svg>`;

        function togglePasswordVisibility(fieldId, button) {
            const field = document.getElementById(fieldId);
            if (field.type === "password") {
                field.type = "text";
                button.innerHTML = eyeClosedSvg;
            } else {
                field.type = "password";
                button.innerHTML = eyeOpenSvg;
            }
        }
    </script>
}

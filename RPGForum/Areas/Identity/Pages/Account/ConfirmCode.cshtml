@page
@model ConfirmCodeModel
@{
    ViewData["Title"] = "Confirmar Código";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="glass-card p-5">
            <div class="text-center mb-4">
                <h2 class="title fw-black">📧 Validar Registo</h2>
                <p class="text-muted">Enviámos um código numérico de 6 dígitos para o teu email.</p>
            </div>

            <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <input type="hidden" asp-for="Input.Email" />
                <input type="hidden" asp-for="Input.Username" />

                <!-- Code Input -->
                <div class="mb-4">
                    <label asp-for="Input.Code" class="form-label fw-semibold">Código de Verificação</label>
                    <input asp-for="Input.Code" class="form-control form-control-custom text-center fs-4" placeholder="123456" maxlength="6" autocomplete="off" style="letter-spacing: 0.5rem; font-weight: 700;" />
                    <span asp-validation-for="Input.Code" class="text-danger small"></span>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-100 btn btn-primary mb-3">
                    🎮 Confirmar Registo
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
